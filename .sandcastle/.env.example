# Copy this file to `.sandcastle/.env` and fill in real values.
# `.sandcastle/.env` is gitignored — never commit secrets.

# Auth options (pick one — `pnpm sandcastle` auto-detects):
#
# 1. Claude Pro/Max subscription (preferred — no key needed)
#    Run `claude login` on the host once so credentials land at
#    ~/.claude/.credentials.json. main.mts bind-mounts ~/.claude and
#    ~/.claude.json into the sandbox so the in-container Claude CLI
#    reuses your subscription.
#    Upstream issue: https://github.com/mattpocock/sandcastle/issues/191
#
# 2. API key fallback — uncomment if you do NOT have a subscription.
# ANTHROPIC_API_KEY=

# Optional: GitHub token used by `gh` inside the sandbox (issue fetching,
# PR creation). Use a fine-grained token with `repo` + `workflow` scopes.
# GITHUB_TOKEN=
